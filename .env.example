# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OBRIGATÓRIOS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Token do bot (obtido no @BotFather)
TELEGRAM_TOKEN=8947553165:AAERkrPMp72K-bQ8uZKm1JPGFR_QML4T9Bs

# Usuário e senha do PRIMEIRO administrador — só é usado na primeira vez
# que o app roda (banco de dados vazio). Depois disso, gerencie usuários
# pela tela "Usuários" dentro do painel — pode até apagar essas duas linhas
# depois que a conta admin já tiver sido criada.
WEB_USER=admin
WEB_PASS=troque_esta_senha_agora

# Chave de sessão do Flask — gere com: openssl rand -hex 32
SECRET_KEY=gere_uma_chave_aleatoria_aqui

# Token que protege a rota /cron/check-and-send — gere com: openssl rand -hex 24
# É o mesmo valor que você vai colocar no "secret" do GitHub Actions.
CRON_SECRET=gere_outro_token_aleatorio_aqui

# Token que o Telegram devolve em cada chamada do webhook, prova que é
# realmente o Telegram chamando (e não outra pessoa) — gere com: openssl rand -hex 24
# É o mesmo valor que você vai usar ao registrar o webhook (ver README).
WEBHOOK_SECRET=gere_mais_um_token_aleatorio_aqui

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPCIONAIS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

TIMEZONE=America/Sao_Paulo
